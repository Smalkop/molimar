{
  "name": "molipar-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --remote",
    "dev:local": "wrangler dev --local",
    "build:css": "tailwindcss -i ./static/css/tailwind.css -o ./static/css/output.css --minify",
    "build": "npm run build:css && node scripts/build.js",
    "deploy": "npm run build && node scripts/upload-static.mjs && wrangler deploy",
    "migrate": "wrangler d1 execute molipar --file=./migrations/001_initial.sql",
    "migrate:local": "wrangler d1 execute molipar --local --file=./migrations/001_initial.sql",
    "seed": "wrangler d1 execute molipar --file=./migrations/002_seed.sql"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "tailwindcss": "^3.4.0",
    "wrangler": "^3.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
